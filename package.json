{
  "name": "jsblender",
  "version": "0.0.0",
  "description": "Modern, typesafe .blend file parser for Blender 5 and up.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "warden": "warden",
    "all": "bun run format:check && bun run lint && bun run typecheck && bun run warden && bun run test"
  },
  "dependencies": {
    "fzstd": "0.1.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.8",
    "@verekia/warden": "0.0.3",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  }
}
